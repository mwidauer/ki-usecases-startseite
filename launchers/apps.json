    "comet":           { "type": "exe", "path": "%LOCALAPPDATA%\\Programs\\Comet\\Comet.exe" },
    "cursor":          { "type": "exe", "path": "%LOCALAPPDATA%\\Programs\\cursor\\Cursor.exe" },
